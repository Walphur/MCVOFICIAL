# Copiá a .env en local. En Render: Environment → Environment Variables

PORT=3000

# PostgreSQL (Render: creá una BD y enlazá DATABASE_URL al Web Service)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Opcional si tu proveedor no exige SSL local:
# DATABASE_SSL=false

# Steam Web API (registro de torneos + escáner /escaner-rapido). Pegá el valor sin comillas.
STEAM_API_KEY=

# Discord: webhook para embeds del escáner (DISCORD_WEBHOOK o DISCORD_WEBHOOK_URL).
DISCORD_WEBHOOK=
# DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
# Canal donde Hexaytron responde (ID numérico). El escáner relee los últimos mensajes acá para enlazar Steam → BattleMetrics.
DISCORD_LOOKUP_CHANNEL_ID=
DISCORD_GUILD_ID=
HEXAYTRON_BOT_ID=

# BattleMetrics: JWT de api.battlemetrics.com (opcional; mejora búsqueda BM en el escáner).
BATTLEMETRICS_TOKEN=

# Reservado: el backend aún no usa STEAM_HISTORY_KEY.
# STEAM_HISTORY_KEY=

# Admin web (login.html → admin.html). Misma clave en Render (Environment).
ADMIN_PASSWORD=
# Obligatorio para login: sin esto el servidor responde 503 en /api/auth/login.
# Generá una clave larga aleatoria, ej: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Sin comillas ni espacios al pegar en Render (o dejá que el servidor haga .trim()).
JWT_SECRET=

# CORS extra (opcional): orígenes adicionales separados por coma. Por defecto el servidor ya permite
# https://mcvoficial.com, www, *.mcvoficial.com, localhost y *.onrender.com (no hace falta paquete cors).
# CORS_ORIGIN=https://staging.ejemplo.com,http://localhost:5173

# URL pública del mismo Web Service (opcional). Si el HTML está en otro dominio, el endpoint /mcv-api-config.js usa esto o RENDER_EXTERNAL_URL.
# PUBLIC_API_URL=https://tu-servicio.onrender.com

# Nota: las imágenes de póster se guardan en /uploads/tournaments/ (carpeta del repo).
# En Render sin disco persistente, los archivos se pierden al redeploy: usá URL externa (PATCH poster_url) o montá un disk en /uploads.
