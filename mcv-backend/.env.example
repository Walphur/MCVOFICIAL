# Copiá a .env en local. En Render: Environment → Environment Variables

PORT=3000

# PostgreSQL (Render: creá una BD y enlazá DATABASE_URL al Web Service)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Opcional si tu proveedor no exige SSL local:
# DATABASE_SSL=false

# Steam Web API (registro de torneos + escáner /escaner-rapido). Pegá el valor sin comillas.
STEAM_API_KEY=

# Discord: webhook para embeds del escáner (DISCORD_WEBHOOK o DISCORD_WEBHOOK_URL).
DISCORD_WEBHOOK=
# DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
# Canal donde Hexaytron responde (ID numérico). El escáner relee los últimos mensajes acá para enlazar Steam → BattleMetrics.
DISCORD_LOOKUP_CHANNEL_ID=
DISCORD_GUILD_ID=
# Opcional: ID del servidor DONDE querés el comando /mcv-wipe (ej. Discord privado del clan).
# Si no lo definís, /mcv-wipe se registra en DISCORD_GUILD_ID. Mismo bot: invitalo al servidor privado con permisos de slash.
# Varios IDs: separados por coma o espacio.
# DISCORD_WIPE_GUILD_ID=
HEXAYTRON_BOT_ID=

# BattleMetrics: JWT de api.battlemetrics.com (opcional; mejora búsqueda BM en el escáner).
BATTLEMETRICS_TOKEN=

# Reservado: el backend aún no usa STEAM_HISTORY_KEY.
# STEAM_HISTORY_KEY=

# Admin web (login.html → admin.html). Misma clave en Render (Environment).
ADMIN_PASSWORD=
# Obligatorio para login: sin esto el servidor responde 503 en /api/auth/login.
# Generá una clave larga aleatoria, ej: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Sin comillas ni espacios al pegar en Render (o dejá que el servidor haga .trim()).
JWT_SECRET=

# CORS: por defecto el servidor refleja cualquier Origin (browser). Para restringir: CORS_STRICT=1 y lista en CORS_ORIGINS.
# CORS_STRICT=1
# CORS_ORIGINS=https://mcvoficial.com,https://www.mcvoficial.com

# URL pública del mismo Web Service (opcional). Si el HTML está en otro dominio, el endpoint /mcv-api-config.js usa esto o RENDER_EXTERNAL_URL.
# PUBLIC_API_URL=https://tu-servicio.onrender.com

# Canal opcional (ID numérico del canal en Discord):
# - Usuario: !mcvsteam 76561198… o un mensaje que sea solo la línea con el SteamID64 (17 dígitos).
# - Bot Hexaytron en el MISMO canal: cada mensaje con SteamID64 en texto/embed se copia al roster del wipe (placeholder hasta que el jugador use /mcv-wipe).
#   Recomendado: definir HEXAYTRON_BOT_ID con el ID de la aplicación del bot Hexaytron. Tras deploy, el servidor relee hasta ~100 mensajes viejos de ese canal.
# DISCORD_WIPE_REGISTER_CHANNEL_ID=

# Lista fija al arrancar el servidor (opcional): SteamID64 separados por coma, espacio o salto de línea.
# Útil en Render si todavía no tenés Discord pegando la lista. Máx. ~500 IDs. Requiere STEAM_API_KEY para nombre/avatar.
# MCV_WIPE_IMPORT_STEAMS=76561198123456789,76561198901234567

# Creadores MCV (GET /api/wipe-list, campo mcv_creator): nombres Steam en minúsculas o SteamID64.
# Por defecto coinciden "ART OF WAR" e "IVAAN" por nombre si no definís nada.
# MCV_WIPE_CREATOR_NAMES=art of war,ivaan
# MCV_WIPE_CREATOR_STEAMS=76561198123456789

# Home (index): cuarto stat “jugadores al wipe”. Pegá el número de confirmados (ej. Hexaytron “Accepted”).
# MCV_HOME_WIPE_PLAYERS=32

# Pósteres de torneos: se guardan bajo esta carpeta (subcarpeta tournaments/). Por defecto = <repo>/uploads (efímero en Render).
# Con un Disk montado en Render (o VPS), apuntá acá el mismo path absoluto del volumen, ej. /var/mcv-uploads
# MCV_UPLOAD_ROOT=/var/mcv-uploads
#
# Sin disco: subí la imagen a un host estático (Imgur, S3, GitHub raw, etc.) y guardá la URL absoluta en poster_url (PATCH /api/admin/tournaments/:slug con poster_url, o SQL).
#
# Imgur (opcional): si pegás un link de álbum /a/…, el backend puede pedir la portada por API y mostrar <img> sin iframe.
# Registrá una app en https://api.imgur.com/oauth2/addclient y pegá el Client ID (solo lectura pública alcanza).
# IMGUR_CLIENT_ID=

# --- Vital Rust stats (solo admin, proxy en backend; API no oficial) ---
# DevTools en vitalrust.com/statistics → Network (XHR/fetch): overview, wipes, statistics?serverId=&wipeId=
# Por defecto el backend usa VITAL_API_PATH_PREFIX=/api/statistics (mismos nombres que en DevTools).
# wipeId=null en URL = estadísticas "Total". Wipe actual = UUID del dropdown (request "wipes").
# VITAL_API_ENABLED=1
# VITAL_API_BASE_URL=https://vitalrust.com
# VITAL_API_PATH_PREFIX=/api/statistics
# VITAL_API_OVERVIEW_PATH=/api/statistics/overview?serverId={serverId}&wipeId={wipeId}
# VITAL_API_WIPES_PATH=/api/statistics/wipes?serverId={serverId}
# VITAL_API_PLAYERS_PATH=/api/statistics?serverId={serverId}&wipeId={wipeId}&category=Player&sortBy=kills&sortAscending=false&page={page}&limit={limit}
# VITAL_API_PLAYER_PATH=/api/statistics/player-overview?userId={steamId64}&serverId={serverId}&wipeId={wipeId}
# MCV juega EU Monthly 2x + EU Medium 2x (por defecto solo esos en el admin).
# MCV_VITAL_SERVER_KEYS=eu-monthly,eu-medium
# VITAL_DEFAULT_SERVER_KEY=eu-monthly
# VITAL_SHOW_ALL_SERVERS=1
# VITAL_SERVERS_JSON=[{"key":"eu-monthly","label":"EU Monthly 2x","serverId":"4"},{"key":"eu-medium","label":"EU Medium 2x","serverId":"5"}]
# Si la API exige sesión Steam, pegá Cookie u otros headers (no commitees esto al repo):
# VITAL_API_HEADERS_JSON={"Cookie":"…"}
# VITAL_API_BEARER=
# VITAL_SERVERS_JSON=[{"key":"eu-10x","label":"EU 10x","serverId":"PEGAR_ID_REAL"}]
# VITAL_CACHE_TTL_SEC=300
# VITAL_API_MIN_INTERVAL_MS=2500
# VITAL_API_MAX_PAGES=5
# VITAL_API_PAGE_SIZE=100
# VITAL_CLAN_EXTRA_STEAMS=
# VITAL_API_USE_WIPE_LIST=1
# VITAL_API_USE_TEAM_ROSTER=1
