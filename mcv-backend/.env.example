# Copiá a .env en local. En Render: Environment → Environment Variables

PORT=3000

# PostgreSQL (Render: creá una BD y enlazá DATABASE_URL al Web Service)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Opcional si tu proveedor no exige SSL local:
# DATABASE_SSL=false

# Steam Web API (registro de torneos + escáner /escaner-rapido). Pegá el valor sin comillas.
STEAM_API_KEY=

# Discord: webhook para embeds del escáner (DISCORD_WEBHOOK o DISCORD_WEBHOOK_URL).
DISCORD_WEBHOOK=
# DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
# Canal donde Hexaytron responde (ID numérico). El escáner relee los últimos mensajes acá para enlazar Steam → BattleMetrics.
DISCORD_LOOKUP_CHANNEL_ID=
DISCORD_GUILD_ID=
# Opcional: ID del servidor DONDE querés el comando /mcv-wipe (ej. Discord privado del clan).
# Si no lo definís, /mcv-wipe se registra en DISCORD_GUILD_ID. Mismo bot: invitalo al servidor privado con permisos de slash.
# Varios IDs: separados por coma o espacio.
# DISCORD_WIPE_GUILD_ID=
HEXAYTRON_BOT_ID=

# BattleMetrics: JWT de api.battlemetrics.com (opcional; mejora búsqueda BM en el escáner).
BATTLEMETRICS_TOKEN=

# Reservado: el backend aún no usa STEAM_HISTORY_KEY.
# STEAM_HISTORY_KEY=

# Admin web (login.html → admin.html). Misma clave en Render (Environment).
ADMIN_PASSWORD=
# Obligatorio para login: sin esto el servidor responde 503 en /api/auth/login.
# Generá una clave larga aleatoria, ej: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Sin comillas ni espacios al pegar en Render (o dejá que el servidor haga .trim()).
JWT_SECRET=

# CORS: por defecto el servidor refleja cualquier Origin (browser). Para restringir: CORS_STRICT=1 y lista en CORS_ORIGINS.
# CORS_STRICT=1
# CORS_ORIGINS=https://mcvoficial.com,https://www.mcvoficial.com

# URL pública del mismo Web Service (opcional). Si el HTML está en otro dominio, el endpoint /mcv-api-config.js usa esto o RENDER_EXTERNAL_URL.
# PUBLIC_API_URL=https://tu-servicio.onrender.com

# Canal opcional (ID numérico del canal en Discord):
# - Usuario: !mcvsteam 76561198… o un mensaje que sea solo la línea con el SteamID64 (17 dígitos).
# - Bot Hexaytron en el MISMO canal: cada mensaje con SteamID64 en texto/embed se copia al roster del wipe (placeholder hasta que el jugador use /mcv-wipe).
#   Recomendado: definir HEXAYTRON_BOT_ID con el ID de la aplicación del bot Hexaytron. Tras deploy, el servidor relee hasta ~100 mensajes viejos de ese canal.
# DISCORD_WIPE_REGISTER_CHANNEL_ID=

# Canal donde postean horas del wipe (ej. "14h", "57 horitas"). Match por Discord ID vía /mcv-wipe.
# Canal #playtime: mensajes con horas (31h, 59hr) se sincronizan al roster vinculado por Discord ID.
# DISCORD_PLAYTIME_CHANNEL_ID=

# Rol Discord que se asigna al usar /mcv-wipe (el rol del bot debe estar ARRIBA del rol objetivo).
# DISCORD_WIPE_LINKED_ROLE_ID=

# Recordatorio automático de quién falta cargar horas (Steam OK, sin horas).
# MCV_WIPE_REMINDER_ENABLED=1
# MCV_WIPE_REMINDER_INTERVAL_HOURS=24
# Canal del aviso (si no se define, usa DISCORD_PLAYTIME_CHANNEL_ID):
# DISCORD_WIPE_REMINDER_CHANNEL_ID=

# Si 1, solo staff (Admin/Manage Guild) puede usar /mcv-reporte:
# --- Asistencia wipe (Accept / Decline / Late) ---
# Rol cuyos miembros se consideran "clan" para recordatorios (opcional; alternativa: roster /mcv-wipe).
# Requiere Guild Members Intent en el portal de Discord + permiso Manage Roles si usás rol al vincular.
# DISCORD_ATTENDANCE_ROLE_ID=
# Rol staff extra para /mcv-asistencia (además de Manage Guild / Admin):
# DISCORD_ATTENDANCE_STAFF_ROLE_ID=

# MCV_WIPE_REPORT_STAFF_ONLY=0

# DISCORD_PLAYTIME_CHANNEL_ID=

# /mcv-reporte y /mcv-sin-horas: si =1, solo admins (Manage Server). Por defecto cualquier miembro del clan puede usarlos.
# MCV_WIPE_REPORT_STAFF_ONLY=1

# Lista fija al arrancar el servidor (opcional): SteamID64 separados por coma, espacio o salto de línea.
# Útil en Render si todavía no tenés Discord pegando la lista. Máx. ~500 IDs. Requiere STEAM_API_KEY para nombre/avatar.
# MCV_WIPE_IMPORT_STEAMS=76561198123456789,76561198901234567

# Creadores MCV (GET /api/wipe-list, campo mcv_creator): nombres Steam en minúsculas o SteamID64.
# Por defecto coinciden "ART OF WAR" e "IVAAN" por nombre si no definís nada.
# MCV_WIPE_CREATOR_NAMES=art of war,ivaan
# MCV_WIPE_CREATOR_STEAMS=76561198123456789

# Home (index): cuarto stat “jugadores al wipe”. Pegá el número de confirmados (ej. Hexaytron “Accepted”).
# MCV_HOME_WIPE_PLAYERS=32

# Home MCV Media (index): últimos videos embebidos
# YOUTUBE_CHANNEL_HANDLE=McompanyV
# YOUTUBE_CHANNEL_ID=UCiUEjzYF6beN96f841IP9qg
# TIKTOK_CHANNEL_HANDLE=mcv_rust
# TIKTOK_VIDEO_URLS=https://www.tiktok.com/@mcv_rust/video/XXXXXXXXX

# Pósteres de torneos: se guardan bajo esta carpeta (subcarpeta tournaments/). Por defecto = <repo>/uploads (efímero en Render).
# Con un Disk montado en Render (o VPS), apuntá acá el mismo path absoluto del volumen, ej. /var/mcv-uploads
# MCV_UPLOAD_ROOT=/var/mcv-uploads
#
# Sin disco: subí la imagen a un host estático (Imgur, S3, GitHub raw, etc.) y guardá la URL absoluta en poster_url (PATCH /api/admin/tournaments/:slug con poster_url, o SQL).
#
# Imgur (opcional): si pegás un link de álbum /a/…, el backend puede pedir la portada por API y mostrar <img> sin iframe.
# Registrá una app en https://api.imgur.com/oauth2/addclient y pegá el Client ID (solo lectura pública alcanza).
# IMGUR_CLIENT_ID=

# --- Seguridad (recomendado en producción) ---
# Contraseña admin (larga, única, no reutilizar). Obligatoria para login.
# ADMIN_PASSWORD=
# JWT firmado HS256, mínimo 12 caracteres (generá: openssl rand -base64 32)
# JWT_SECRET=
# CORS: en producción activá lista blanca (solo tu dominio puede llamar la API desde el navegador)
# CORS_STRICT=1
# CORS_ORIGINS=https://mcvoficial.com,https://www.mcvoficial.com
# Opcional: solo estas IPs pueden hacer login y usar /api/admin (IP pública de tu casa/oficina, coma-separadas)
# ADMIN_IP_ALLOWLIST=
# Rate limits (por IP): intentos login / 15 min, escáner / min, forms públicos / min
# RATE_LIMIT_LOGIN_MAX=10
# RATE_LIMIT_SCANNER_MAX=8
# RATE_LIMIT_PUBLIC_WRITE_MAX=25
# RATE_LIMIT_ADMIN_WRITE_MAX=120
# Con Cloudflare delante de Render (proxy naranja): TRUST_PROXY_HOPS=2
# TRUST_PROXY_HOPS=2
# NODE_ENV=production
# Cloudflare Turnstile (login admin) — https://dash.cloudflare.com → Turnstile
# Site key: pública (también la lee login.html vía /api/auth/login-config)
# Secret key: SOLO en Render, nunca en el repo ni en el HTML
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# OAuth admin (opcional) — ver docs/SEGURIDAD-SITIO-Y-OAUTH.md
# OAUTH_PUBLIC_BASE_URL=https://mcvoficial.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ADMIN_OAUTH_GOOGLE_EMAILS=staff@gmail.com
# ADMIN_OAUTH_STEAM_IDS=76561198000000000
# STEAM_OPENID_REALM=https://mcvoficial.com

# Cuentas públicas (Steam/Google) — ver docs/SEGURIDAD-SITIO-Y-OAUTH.md
# Mismas credenciales Google; redirect extra: /api/auth/user/google/callback
# PUBLIC_USER_STEAM=1
# PUBLIC_USER_GOOGLE=1
# REQUIRE_USER_AUTH_TICKETS=1

# --- Vital Rust stats (API playerstatistics.vitalgamenetwork.com) ---
# Link stats clan: vital-rust.html — login Steam + SteamID64 en roster (Info jugadores / extras).
# VITAL_PUBLIC_ACCESS_KEY=   (opcional, solo API legacy con ?key=; la web ya no lo usa)

# Lista torretas (torretas.html): SteamID64 de torreteros autorizados (también editable en admin → Vital → Torreteros).
# TURRET_OPERATOR_STEAMS=76561198…,76561199…
# MCV juega EU Monthly 2x (serverId 16) y EU Medium 2x (serverId 19) — mismo id que ?serverId= en vitalrust.com/statistics
# VITAL_API_ENABLED=1
# VITAL_API_BASE_URL=https://playerstatistics.vitalgamenetwork.com
# MCV_VITAL_SERVER_KEYS=eu-monthly,eu-medium
# VITAL_DEFAULT_SERVER_KEY=eu-monthly
# MCV_YO_SERVER_KEY=eu-medium   (/mcv-yo: wipe Vital EU Medium; si no hay stats, prueba EU Monthly)
# VITAL_SHOW_ALL_SERVERS=1
# VITAL_API_PLAYER_INCLUDES=combat,raiding,farming,pve,building
# VITAL_CACHE_TTL_SEC=300
# VITAL_API_MIN_INTERVAL_MS=2500
# VITAL_API_POST_TIMEOUT_MS=40000
# VITAL_CLAN_CHUNK_SIZE=25
# VITAL_BUILDING_CHUNK_SIZE=18
# VITAL_CLAN_EXTRA_STEAMS=   (legacy; preferir lista en admin → Vital → Jugadores extra)
# VITAL_API_USE_WIPE_LIST=1
# VITAL_API_USE_TEAM_ROSTER=1
# VITAL_API_USE_PLAYER_INFO=1   (Info jugadores: activos en wipe con SteamID64 → roster Vital)
# Overrides opcionales (por defecto ya apuntan a /servers/{id}/aggregations/overview, /wipes, POST /players/overview):
# VITAL_API_OVERVIEW_PATH=
# VITAL_API_OVERVIEW_TOTAL_PATH=
# VITAL_API_WIPES_PATH=
# VITAL_API_WIPES_CURRENT_PATH=
# VITAL_API_PLAYERS_OVERVIEW_POST=
