# Copiá a .env en local. En Render: Environment → Environment Variables

PORT=3000

# PostgreSQL (Render: creá una BD y enlazá DATABASE_URL al Web Service)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Opcional si tu proveedor no exige SSL local:
# DATABASE_SSL=false

# Steam Web API (registro + escáner)
STEAM_API_KEY=

# Discord (opcional cada uno)
DISCORD_WEBHOOK=
DISCORD_BOT_TOKEN=
DISCORD_LOOKUP_CHANNEL_ID=
DISCORD_GUILD_ID=
HEXAYTRON_BOT_ID=

# Admin web (login.html → admin.html)
ADMIN_PASSWORD=
JWT_SECRET=

# CORS (opcional, ej. https://tu-dominio.onrender.com)
# CORS_ORIGIN=
